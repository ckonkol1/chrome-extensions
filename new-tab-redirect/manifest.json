{
  "manifest_version": 3,
  "name": "New Tab Redirect",
  "version": "1.0.0",
  "description": "Redirects new tabs to a configured URL",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
